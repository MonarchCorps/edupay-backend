PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/edupay

# Nomba credentials (from sandbox dashboard)
NOMBA_CLIENT_ID=your_client_id
NOMBA_CLIENT_SECRET=your_client_secret
NOMBA_ACCOUNT_ID=your_parent_account_id
NOMBA_BASE_URL=https://api.nomba.com

# Nomba webhook signature secret (Nomba Dashboard → Developer → Webhook Setup)
NOMBA_WEBHOOK_SECRET=your_webhook_signature_key

# Internal API key salt (any 32+ char random string)
API_KEY_SALT=change_this_to_a_random_32_char_string

NODE_ENV=development
